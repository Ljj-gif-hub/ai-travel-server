server:
  port: ${SERVER_PORT:3200}
  servlet:
    encoding:
      charset: UTF-8
      enabled: true
      force: true
  error:
    include-stacktrace: never
    include-message: never

spring:
  application:
    name: travel-java
  http:
    encoding:
      charset: UTF-8
      enabled: true
      force: true
  datasource:
    url: ${DB_URL:jdbc:h2:file:./data/travel_plans;MODE=MySQL;DB_CLOSE_DELAY=-1;AUTO_SERVER=TRUE}
    driver-class-name: ${DB_DRIVER:org.h2.Driver}
    username: ${DB_USERNAME:sa}
    password: ${DB_PASSWORD:}
  jpa:
    hibernate:
      ddl-auto: ${JPA_DDL_AUTO:update}
    show-sql: ${JPA_SHOW_SQL:false}
    properties:
      hibernate:
        format_sql: true
    open-in-view: false
  data:
    redis:
      host: ${REDIS_HOST:localhost}
      port: ${REDIS_PORT:6379}
      password: ${REDIS_PASSWORD:}
      timeout: ${REDIS_TIMEOUT:6000ms}

app:
  cors:
    allowed-origins: ${CORS_ORIGINS:http://localhost:5173,http://localhost:5177}

# DeepSeek-V4 Pro 大模型配置
deepseek:
  api-key: ${DEEPSEEK_API_KEY:}           # DeepSeek API Key (sk-xxxx格式)
  base-url: ${DEEPSEEK_BASE_URL:https://api.deepseek.com}
  model: ${DEEPSEEK_MODEL:deepseek-chat}   # deepseek-chat / deepseek-reasoner
  max-tokens: ${DEEPSEEK_MAX_TOKENS:4096}
  temperature: ${DEEPSEEK_TEMPERATURE:0.7}

jwt:
  secret: ${JWT_SECRET:}
  expiration: ${JWT_EXPIRATION:86400000}

baidu:
  map:
    ak: ${BAIDU_MAP_AK:}

ai:
  image:
    endpoint: ${AI_IMAGE_ENDPOINT:https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image}
    api-key: ${AI_IMAGE_API_KEY:}
    timeout: ${AI_IMAGE_TIMEOUT:30000}

# ============================================
# 环境变量配置说明
# ============================================
# 使用方式：
# 1. 开发环境：复制此文件为 application.yml 并填写真实值
# 2. 生产环境：通过系统环境变量或启动参数注入
#
# 启动参数示例：
# java -jar travel-java.jar \
#   --DEEPSEEK_API_KEY=sk-your-api-key \
#   --JWT_SECRET=your-256-bit-secret-key \
#   --BAIDU_MAP_AK=your-baidu-map-ak \
#   --REDIS_HOST=your-redis-host \
#   --CORS_ORIGINS=https://your-domain.com
#
# 系统环境变量（Linux/macOS）：
# export DEEPSEEK_API_KEY=sk-your-api-key
# export JWT_SECRET=your-256-bit-secret-key
# export BAIDU_MAP_AK=your-baidu-map-ak
# export REDIS_HOST=localhost
# export CORS_ORIGINS=https://your-domain.com
# java -jar travel-java.jar
#
# 系统环境变量（Windows PowerShell）：
# $env:DEEPSEEK_API_KEY="sk-your-api-key"
# $env:JWT_SECRET="your-256-bit-secret-key"
# $env:BAIDU_MAP_AK="your-baidu-map-ak"
# $env:REDIS_HOST="localhost"
# $env:CORS_ORIGINS="https://your-domain.com"
# java -jar travel-java.jar
